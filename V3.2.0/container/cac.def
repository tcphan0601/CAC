Bootstrap: docker
From: ubuntu:22.04

%help
    This container builds and installs deepmd-kit (v3.1.0) and the CAC application.
    It uses a Python virtual environment to manage TensorFlow dependencies.

%files
    # Copy your CAC source into the container
    ./src /app
    ./container/Makefile.container /app/src/Makefile

%environment
    export PATH="/opt/venv/bin:/usr/local/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/venv/lib/python3.10/site-packages/tensorflow:/usr/local/lib:$LD_LIBRARY_PATH"

%post
    export DEBIAN_FRONTEND=noninteractive

    # 1. Install required system packages for building DeePMD, MPI, and CAC
    apt-get update && apt-get install -y \
        build-essential \
        cmake \
        git \
        python3 \
        python3-venv \
        python3-pip \
        python3-dev \
        libopenmpi-dev \
        openmpi-bin \
        wget \
        vim \
        && rm -rf /var/lib/apt/lists/*

    # 2. Set up Python Virtual Environment
    python3 -m venv /opt/venv
    . /opt/venv/bin/activate
    
    # Upgrade pip and install build dependencies for python
    pip install --no-cache-dir --upgrade pip setuptools wheel
    pip install --no-cache-dir tensorflow-cpu==2.19.0

    # 3. Build DeepMD-kit from source
    cd /tmp
    rm -rf /tmp/deepmd-kit
    git clone --recursive -b v3.1.0 https://github.com/deepmodeling/deepmd-kit.git
    cd deepmd-kit/source && mkdir build && cd build
    cmake \
      -DENABLE_TENSORFLOW=TRUE \
      -DUSE_TF_PYTHON_LIBS=TRUE \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      ..
    make -j$(nproc)
    make install

    # 4. Build the CAC application
    # The source files are copied into /app by the %files section before %post runs.
    cd /app
    mkdir -p obj
    cp DEEPMD/pair_* ./
    grep -q -F '#include "pair_base.h"' style_pair.h
    grep -q -F '#include "pair_deepmd.h"' style_pair.h
    make -j$(nproc)
    # Install the executable to a standard location and rename it
    cp cac.3.2.0 /usr/local/bin/cac
    chmod +x /usr/local/bin/cac
    cp TECPLOT/lib/libtecio.so /usr/local/lib
   

    # 5. Cleanup
    cd /
    rm -rf /tmp/deepmd-kit 

%runscript
    exec cac "$@"
