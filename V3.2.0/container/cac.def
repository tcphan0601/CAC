Bootstrap: docker
From: ubuntu:22.04

%help
    This container builds and installs deepmd-kit and the CAC application based on the user-provided Dockerfile.

%post
    # Avoid interactive prompts during installation
    export DEBIAN_FRONTEND=noninteractive

    # Install essential build tools, Python, Git, and MPI
    apt-get update && apt-get install -y \
        build-essential \
        cmake \
        git \
        python3 \
        python3-venv \
        python3-pip \
        vim \
        tmux \
        openmpi-bin \
        libopenmpi-dev \
        && rm -rf /var/lib/apt/lists/*

    # Set up a Python virtual environment and install TensorFlow
    python3 -m venv /opt/venv
    # Activate venv for subsequent commands in this section
    . /opt/venv/bin/activate
    pip install --no-cache-dir tensorflow-cpu==2.19.0

    # --- Build DeepMD-kit from source ---
    cd /tmp
    rm -rf /tmp/deepmd-kit
    git clone --recursive -b v3.1.0 https://github.com/deepmodeling/deepmd-kit.git
    cd deepmd-kit/source && mkdir build && cd build
    cmake \
      -DENABLE_TENSORFLOW=TRUE \
      -DUSE_TF_PYTHON_LIBS=TRUE \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      ..
    make -j$(nproc)
    make install

    # --- Build the CAC application ---
    # The source files are copied into /app by the %files section before %post runs.
    cd /app
    cp DEEPMD/pair* DEEPMD/deepmd_version.h ./
	  grep -q -F '#include "pair_deepmd.h"' style_pair.h || echo '#include "pair_deepmd.h"' >> style_pair.h
	  grep -q -F '#include "pair_base.h"' style_pair.h || echo '#include "pair_base.h"' >> style_pair.h

    mkdir -p obj
    make -j$(nproc)
    # Install the executable to a standard location and rename it
    cp cac.3.2.0 /usr/local/bin/cac
    cp TECPLOT/lib/libtecio.so /usr/local/lib

    # Clean up the source code to keep the image small
    cd / && rm -rf /tmp/deepmd-kit /app

%files
    # Copy the CAC source code from the host into /app in the container.
    # This happens BEFORE the %post section runs.
    ./src /app
    ./container/Makefile.container /app/Makefile

%environment
    # Set environment variables needed at runtime.
    # These are activated when the container is run.
    export PATH="/opt/venv/bin:/usr/local/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/venv/lib/python3.10/site-packages/tensorflow:/usr/local/lib:$LD_LIBRARY_PATH"

%runscript
    exec cac "$@"
